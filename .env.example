# Capstone demo environment — copy to .env before `docker compose up` or `make eval-live`
# For `make eval-offline` and the default Streamlit demo flow, no API key is required.

# --- Required for `make eval-live` and live LLM calls in the demo ---
# OPENAI_API_KEY=sk-...

# --- Model selection ---
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.1

# --- Backend ---
BACKEND_URL=http://localhost:8001
BACKEND_PORT=8001

# --- Demo / monitoring ports ---
DEMO_UI_PORT=8502
DASHBOARD_PORT=8501

# --- Demo mode ---
# When true, the agent router only allow-lists 2 collections (recipes, nutrition_science)
# and other collections respond with a "production-only" message.
DEMO_MODE=true

# --- Cost guardrail (protects OPENAI_API_KEY when deployed publicly) ---
# Per-session cap + global daily $ budget. When either is hit, the agent
# falls back to deterministic mode (no LLM call). See docs/deployment.md.
CAPSTONE_DAILY_BUDGET_USD=0.50
CAPSTONE_SESSION_LLM_CAP=20
CAPSTONE_SESSION_LLM_WINDOW_S=3600

# --- FastAPI middleware rate limiting (separate from the agent cost guardrail) ---
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# --- Storage ---
FEEDBACK_DB_PATH=monitoring/feedback.db
RATE_LIMIT_DB_PATH=monitoring/rate_limit.db
LOGS_DIR=ai/week1-rag/logs
